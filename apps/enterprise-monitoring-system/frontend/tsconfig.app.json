{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src", 
    "../../../Recruitment & Hiring_1/ADMIN_SYSTEM", 
    "../../../Recruitment & Hiring_1/CEO_SYSTEM", 
    "../../../Recruitment & Hiring_1/EMPLOYEE_SYSTEM", 
    "../../../Recruitment & Hiring_1/HR_SYSTEM", 
    "../../../Recruitment & Hiring_1/MANAGER_SYSTEM", 
    "../../../Recruitment & Hiring_1/TECHLEAD_SYSTEM", 
    "../../../Recruitment & Hiring_1/MARKETING_SYSTEM", 
    "../../../Recruitment & Hiring_1/SUPPORT_SYSTEM"
  ]
}
