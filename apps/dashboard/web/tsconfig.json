{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "typeRoots": [
      "./node_modules/@types"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@new_project/*": [
        "../../enterprise-monitoring-system/frontend/*"
      ],
      "lucide-react": [
        "./node_modules/lucide-react"
      ],
      "recharts": [
        "./node_modules/recharts"
      ],
      "react": [
        "./node_modules/@types/react/index.d.ts"
      ],
      "react/jsx-runtime": [
        "./node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react-dom": [
        "./node_modules/@types/react-dom/index.d.ts"
      ],
      "@types/react": [
        "./node_modules/@types/react/index.d.ts"
      ],
      "@types/react-dom": [
        "./node_modules/@types/react-dom/index.d.ts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "src/external",
    "../../enterprise-monitoring-system/frontend/node_modules",
    "../../enterprise-monitoring-system/frontend/dist",
    "../../enterprise-monitoring-system/frontend/**/venv"
  ]
}
