{
  "name": "liveguard-desktop-agent",
  "version": "1.0.0",
  "description": "LiveGuard Windows Monitoring Agent",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.liveguard.agent",
    "productName": "LiveGuard Agent",
    "win": { "target": "nsis", "icon": "assets/icon.ico" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "createDesktopShortcut": true }
  },
  "dependencies": {
    "axios": "^1.6.7",
    "node-cron": "^3.0.3",
    "screenshot-desktop": "^1.15.0",
    "active-win": "^8.2.1",
    "systeminformation": "^5.21.0",
    "ws": "^8.16.0",
    "form-data": "^4.0.0",
    "node-machine-id": "^1.1.12",
    "electron-log": "^5.0.1"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  }
}
