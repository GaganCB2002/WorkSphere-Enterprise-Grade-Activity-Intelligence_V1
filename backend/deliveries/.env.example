# WorkSphere Environment Configuration

# Backend Services
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worksphere

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Services URLs
DASHBOARD_BACKEND_URL=http://localhost:4000
TRACKINH_URL=http://localhost:5002
ENTERPRISE_API_URL=http://localhost:5001
FRONTEND_URL=http://localhost:3005

# Optional: AI Services
AI_SERVICE_URL=http://localhost:8000

# Logging
LOG_LEVEL=info
