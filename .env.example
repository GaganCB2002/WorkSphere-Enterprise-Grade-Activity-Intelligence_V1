# ─── WorkSphere Enterprise — Environment Configuration ───────────────────────

# ─── Backend API (Express + Socket.io) ───────────────────────────────────────
# Deploy this separately on Railway / Render / VPS
# The frontend proxies /api requests to this backend during dev

PORT=5001
NODE_ENV=development

# ─── MongoDB (for user, employee, attendance data) ──────────────────────────
MONGO_URI=mongodb://localhost:27017/worksphere

# ─── PostgreSQL via Prisma (for CEO dashboards, OKRs, financials) ───────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worksphere
# For Prisma: use "file:./dev.db" for local SQLite development

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production

# ─── CORS ────────────────────────────────────────────────────────────────────
HR_URL=http://localhost:3005

# ─── Frontend (Vite) — Set these in Vercel Environment Variables ────────────
# VITE_API_BASE_URL=https://worksphere-enterprise-grade-activity.onrender.com/api
# VITE_WEBSOCKET_URL=wss://worksphere-enterprise-grade-activity.onrender.com
# VITE_MAIN_AUTH_API_URL=https://worksphere-enterprise-grade-activity.onrender.com
